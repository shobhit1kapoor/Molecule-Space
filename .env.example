# Optional Qdrant Cloud settings. If omitted, MolSpace uses local persistent Qdrant client mode.
QDRANT_URL=
QDRANT_API_KEY=

# Backend behavior
MOLSPACE_COLLECTION=molspace_molecules
MOLSPACE_MAX_RECORDS=1000
MOLSPACE_AUTO_BUILD=0
MOLSPACE_DISABLE_CHEMBL=0

# Frontend
VITE_API_BASE_URL=http://localhost:8000

